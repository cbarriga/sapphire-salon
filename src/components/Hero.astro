---
const heroSlides = [
  { src: "/images/CB_20141006-Sapphire-Salon_9514.jpg", alt: "Sapphire Salon — hair styling" },
  { src: "/images/CB_20141006-Sapphire-Salon_9525.jpg", alt: "Sapphire Salon — hair coloring" },
  { src: "/images/CB_20141006-Sapphire-Salon_9528.jpg", alt: "Sapphire Salon — hair care" },
  { src: "/images/CB_20141006-Sapphire-Salon_9543.jpg", alt: "Sapphire Salon — styling" },
  { src: "/images/CB_20141006-Sapphire-Salon_9547.jpg", alt: "Sapphire Salon — services" },
];
---

<section class="hero" id="salon" aria-label="Salon photos">
  <div class="hero-track" id="heroTrack">
    {heroSlides.map(slide => (
      <div class="hero-slide">
        <img src={slide.src} alt={slide.alt} />
      </div>
    ))}
  </div>
  <button class="hero-arrow hero-prev" id="heroPrev" aria-label="Previous">&#8249;</button>
  <button class="hero-arrow hero-next" id="heroNext" aria-label="Next">&#8250;</button>
  <div class="hero-dots">
    {heroSlides.map((_, i) => (
      <button class:list={["hero-dot", { active: i === 0 }]} data-index={i} aria-label={`Slide ${i + 1}`} />
    ))}
  </div>
</section>

<script>
const track = document.getElementById('heroTrack') as HTMLElement;
const dots = document.querySelectorAll<HTMLElement>('.hero-dot');
let cur = 0;
let timer: ReturnType<typeof setInterval>;

function goTo(n: number) {
  cur = ((n % dots.length) + dots.length) % dots.length;
  track.style.transform = `translateX(-${cur * 100}%)`;
  dots.forEach((d, i) => d.classList.toggle('active', i === cur));
}
function restart() { clearInterval(timer); timer = setInterval(() => goTo(cur + 1), 5000); }

document.getElementById('heroPrev')?.addEventListener('click', () => { goTo(cur - 1); restart(); });
document.getElementById('heroNext')?.addEventListener('click', () => { goTo(cur + 1); restart(); });
dots.forEach(d => d.addEventListener('click', () => { goTo(Number(d.dataset.index)); restart(); }));
restart();
</script>
