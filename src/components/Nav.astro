---
<nav id="site-nav">
  <a href="#" class="nav-logo" aria-label="Sapphire Salon NH">
    <img src="/images/header.png" alt="Sapphire Salon" height="30" />
  </a>

  <button class="mobile-toggle" id="mobileToggle" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <ul id="navLinks">
    <li><a href="#salon">The Salon</a></li>
    <li><a href="#services">Our Services</a></li>
    <li><a href="#ourteam">Meet Our Team</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<script>
const toggle = document.getElementById('mobileToggle');
const navLinks = document.getElementById('navLinks');
toggle?.addEventListener('click', () => {
  const open = navLinks?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
});
navLinks?.querySelectorAll('a').forEach(a =>
  a.addEventListener('click', () => { navLinks.classList.remove('open'); })
);
</script>
