      </tbody>
    </table>
  </div>

  <!-- SKIN CARE -->
  <div class="tab-panel" id="tab-skincare" role="tabpanel">
    <table class="services-table">
      <thead><tr><th>NAME</th><th>PRICE</th></tr></thead>
      <tbody>
        <tr><td>Basic Facial</td><td class="price">$85</td></tr>
        <tr><td>Anti-Aging Facial</td><td class="price">$100</td></tr>
        <tr><td>Hydrating Facial</td><td class="price">$95</td></tr>
        <tr><td>Teen Facial</td><td class="price">$65</td></tr>
        <tr><td>Spray Tan</td><td class="price">$50</td></tr>
      </tbody>
    </table>
  </div>

  <!-- FACIAL WAXING -->
  <div class="tab-panel" id="tab-facial-waxing" role="tabpanel">
    <table class="services-table">
      <thead><tr><th>NAME</th><th>PRICE</th></tr></thead>
