<section class="services" id="services">
  <h2>Our Services</h2>

  <div class="tab-bar" role="tablist">
    <button
      class="tab-btn active"
      data-tab="eyelashes"
      role="tab"
      aria-selected="true">Eyelashes &amp; Eyebrows</button
    >
    <button class="tab-btn" data-tab="skincare" role="tab" aria-selected="false"
      >Skin Care</button
    >
    <button class="tab-btn" data-tab="facial" role="tab" aria-selected="false"
      >Facial Waxing</button
    >
    <button class="tab-btn" data-tab="body" role="tab" aria-selected="false"
      >Body Waxing</button
    >
    <button class="tab-btn" data-tab="hair" role="tab" aria-selected="false"
      >Hair Care</button
    >
  </div>

  <div class="tab-panels">
    <div class="tab-panel active" id="tab-eyelashes">
      <table>
        <thead><tr><th>NAME</th></tr></thead><tbody>
          <tr><td>Eyelash Extensions Full Set</td></tr>
          <tr><td>Eyelash Fills</td></tr>
          <tr><td>Lash Lift</td></tr>
          <tr><td>Lash Lift &amp; Tint Combo</td></tr>
        </tbody>
      </table>
    </div>

    <div class="tab-panel" id="tab-skincare">
      <table>
        <thead><tr><th>NAME</th></tr></thead><tbody>
          <tr><td>Basic Facial</td></tr>
          <tr><td>Anti-Aging Facial</td></tr>
          <tr><td>Hydrating Facial</td></tr>
          <tr><td>Teen Facial</td></tr>
        </tbody>
      </table>
    </div>

    <div class="tab-panel" id="tab-facial">
      <table>
        <thead><tr><th>NAME</th></tr></thead><tbody>
          <tr><td>Brow</td></tr>
          <tr><td>Chin</td></tr>
          <tr><td>Nose</td></tr>
          <tr><td>Lip</td></tr>
          <tr><td>Ear</td></tr>
          <tr><td>Full Face</td></tr>
        </tbody>
      </table>
    </div>

    <div class="tab-panel" id="tab-body">
      <table>
        <thead><tr><th>NAME</th></tr></thead><tbody>
          <tr><td>Bikini (Line)</td></tr>
          <tr><td>Bikini (Extra)</td></tr>
          <tr><td>Bikini (Front)</td></tr>
          <tr><td>Brazilian</td></tr>
          <tr><td>Half Legs</td></tr>
          <tr><td>Full Legs</td></tr>
          <tr><td>Half Arms</td></tr>
          <tr><td>Full Arms</td></tr>
          <tr><td>Half Back</td></tr>
          <tr><td>Full Back</td></tr>
          <tr><td>Chest</td></tr>
          <tr><td>Underarms</td></tr>
        </tbody>
      </table>
    </div>

    <div class="tab-panel" id="tab-hair">
      <table>
        <tbody>
          <tr class="sub-head"><th colspan="1">Cuts</th></tr>
          <tr><td>Kids Cut 0–3 years old</td></tr>
          <tr><td>Kids Cut 4–10 years old</td></tr>
          <tr><td>Teen Boys 11–17 years old</td></tr>
          <tr><td>Teen Girls 11–17 years old</td></tr>
          <tr><td>Men's Classic Cut</td></tr>
          <tr><td>Womens Wash, Cut &amp; Blow Dry</td></tr>

          <tr class="sub-head"><th colspan="1">Styling</th></tr>
          <tr><td>Wash &amp; Blowdry</td></tr>
          <tr><td>Wash, Blowdry &amp; Style</td></tr>
          <tr><td>Formal Styling &amp; Updo</td></tr>

          <tr class="sub-head"><th colspan="1">Colors</th></tr>
          <tr><td>Color Re-touch</td></tr>
          <tr><td>Color Re-touch w/ Color Balance</td></tr>
          <tr><td>Highlights — Full</td></tr>
          <tr><td>— With lowlights</td></tr>
          <tr><td>Highlights — Partial</td></tr>
          <tr><td>— With lowlights</td></tr>
          <tr
            ><td
              >Highlights — Face Frame <span class="note"
                >10–15 foils placed around hairline and crown areas to brighten
                up around the face or add a little dimension.</span
              ></td
            ></tr
          >
          <tr
            ><td
              >Highlight &amp; Lowlight Full Foil <span class="note"
                >Full head multi-dimensional foil including both highlights and
                lowlights.</span
              ></td
            ></tr
          >
          <tr
            ><td
              >Highlight &amp; Lowlight Partial Foil <span class="note"
                >Partial head multi-dimensional foil including both highlights
                and lowlights.</span
              ></td
            ></tr
          >
          <tr
            ><td
              >Semi-Permanent Color <span class="note"
                >Deposit-only, ammonia-free demi-permanent color. 27
                intermixable shades.</span
              ></td
            ></tr
          >
          <tr
            ><td
              >Virgin Color Application <span class="note"
                >All-over permanent color from scalp to ends on previously
                uncolored hair.</span
              ></td
            ></tr
          >

          <tr class="sub-head"><th colspan="1">Specialty Colors</th></tr>
          <tr><td>Ombré</td></tr>
          <tr><td>Balayage</td></tr>

          <tr class="sub-head"><th colspan="1">Re-texturizing</th></tr>
          <tr
            ><td
              >Keratin Smoothing Treatment <span class="note"
                >Aldehyde-free &amp; formaldehyde-free. Adds volume, smooths,
                and restores youthful texture for a minimum of 4 months.</span
              ></td
            ></tr
          >
          <tr
            ><td
              >Keratin Express Treatment <span class="note"
                >100% formaldehyde-free amino acid express treatment. Up to 4
                weeks of softer, frizz-free hair.</span
              ></td
            ></tr
          >
        </tbody>
      </table>
    </div>
  </div><!-- .tab-panels -->
</section>

<script>
  document.querySelectorAll<HTMLElement>(".tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".tab-btn").forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      document
        .querySelectorAll(".tab-panel")
        .forEach((p) => p.classList.remove("active"));
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");
      document
        .getElementById("tab-" + btn.dataset.tab)
        ?.classList.add("active");
    });
  });
</script>
