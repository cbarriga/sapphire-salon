        <tr><td>Brow</td><td class="price">$20</td></tr>
        <tr><td>Chin</td><td class="price">$18</td></tr>
        <tr><td>Nose</td><td class="price">$15</td></tr>
        <tr><td>Lip</td><td class="price">$15</td></tr>
        <tr><td>Ear</td><td class="price">$15</td></tr>
        <tr><td>Full Facial</td><td class="price">$50</td></tr>
      </tbody>
    </table>
  </div>

  <!-- BODY WAXING -->
  <div class="tab-panel" id="tab-body-waxing" role="tabpanel">
    <table class="services-table">
      <thead>
        <tr><th>NAME</th><th>PRICE</th><th>NAME</th><th>PRICE</th></tr>
      </thead>
      <tbody>
        <tr><td>Bikini (Line)</td><td class="price">$45</td><td>Bikini (Extra)</td><td class="price">$50</td></tr>
        <tr><td>Bikini (Front)</td><td class="price">$65</td><td>Brazilian</td><td class="price">$70</td></tr>
        <tr><td>Half Legs</td><td class="price">$55</td><td>Full Legs</td><td class="price">$100</td></tr>
        <tr><td>Half Arms</td><td class="price">$30</td><td>Full Arms</td><td class="price">$40</td></tr>
        <tr><td>Half Back</td><td class="price">$30</td><td>Full Back</td><td class="price">$40</td></tr>
        <tr><td>Chest</td><td class="price">$50</td><td>Underarms</td><td class="price">$25</td></tr>
      </tbody>
    </table>
  </div>

  <!-- HAIR CARE -->
  <div class="tab-panel" id="tab-haircare" role="tabpanel">
    <table class="services-table">
      <tbody>
        <tr><th class="section-header" colspan="2">CUTS</th></tr>
