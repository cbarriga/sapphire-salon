<section class="services" id="services">
  <h2>Our Services</h2>

  <div class="tab-nav" role="tablist" aria-label="Service categories">
    <button class="tab-btn active" data-tab="eyelashes" role="tab" aria-selected="true" aria-controls="tab-eyelashes">Eyelashes &amp; Eyebrows</button>
    <button class="tab-btn" data-tab="skincare" role="tab" aria-selected="false" aria-controls="tab-skincare">Skin Care</button>
    <button class="tab-btn" data-tab="facial-waxing" role="tab" aria-selected="false" aria-controls="tab-facial-waxing">Facial Waxing</button>
    <button class="tab-btn" data-tab="body-waxing" role="tab" aria-selected="false" aria-controls="tab-body-waxing">Body Waxing</button>
    <button class="tab-btn" data-tab="haircare" role="tab" aria-selected="false" aria-controls="tab-haircare">Hair Care</button>
  </div>

  <!-- EYELASHES & EYEBROWS -->
  <div class="tab-panel active" id="tab-eyelashes" role="tabpanel">
    <table class="services-table">
      <thead><tr><th>NAME</th><th>PRICE</th></tr></thead>
      <tbody>
        <tr><td>Eyelash Extensions Full Set</td><td class="price">$160</td></tr>
        <tr><td>Eyelash Fills</td><td class="price">$50</td></tr>
        <tr><td>Lash Lift</td><td class="price">$80</td></tr>
