        <tr><td>Teen Boys — 11 to 17 years old</td><td class="price">$20</td></tr>
        <tr><td>Teen Girls — 11 to 17 years old</td><td class="price">$25</td></tr>
        <tr><td>Men's Classic Cut</td><td class="price">$22</td></tr>
        <tr><td>Men's Fade Cut</td><td class="price">$25</td></tr>
        <tr><td>Womens Wash, Cut &amp; Blow Dry</td><td class="price">$33</td></tr>
        <tr><td>— Added Style: Flat or Curling Iron</td><td class="price">$10</td></tr>

        <tr><th class="section-header" colspan="2">BLOWOUTS &amp; STYLING</th></tr>
        <tr><td>Wash &amp; Blowdry</td><td class="price">$20</td></tr>
        <tr><td>Wash, Blowdry &amp; Style</td><td class="price">$30</td></tr>
        <tr><td>Formal Styling &amp; Updo</td><td class="price">$55 &amp; up</td></tr>

        <tr><th class="section-header" colspan="2">COLOR</th></tr>
        <tr><td>Color Re-touch</td><td class="price">$57</td></tr>
        <tr><td>Color Re-touch w/ Color Balance</td><td class="price">$69</td></tr>
        <tr><td>Highlights — Full</td><td class="price">$105</td></tr>
        <tr><td>— With Lowlights</td><td class="price">$117</td></tr>
        <tr><td>Highlights — Partial</td><td class="price">$80</td></tr>
        <tr><td>— With Lowlights</td><td class="price">$87</td></tr>
        <tr>
          <td>
            Highlights — Face Frame
            <span class="note">10–15 foils placed around hairline and crown areas to brighten up around the face or add dimension.</span>
          </td>
          <td class="price">$50</td>
        </tr>
        <tr>
          <td>
            Highlight &amp; Lowlight — Full Foil
            <span class="note">Full head multi-dimensional foil including both highlights and lowlights.</span>
          </td>
          <td class="price">$112</td>
        </tr>
        <tr>
          <td>
            Highlight &amp; Lowlight — Partial Foil
            <span class="note">Partial head multi-dimensional foil including both highlights and lowlights.</span>
          </td>
          <td class="price">$87</td>
        </tr>
        <tr><td>Any type of toner added to foils</td><td class="price">$12 per color</td></tr>
        <tr>
          <td>
            PM SHINES™ Gloss Treatment
            <span class="note">Clear shine gloss with Intense Hydrating Complex — penetrates deep to hydrate and replenish amino acids.</span>
          </td>
          <td class="price">$35</td>
        </tr>
        <tr>
          <td>
            Semi-Permanent Color
            <span class="note">PM SHINES™ deposit-only, ammonia-free demi-permanent color. 27 intermixable shades.</span>
          </td>
          <td class="price">$45</td>
        </tr>
        <tr>
          <td>
            Virgin Color Application
            <span class="note">All-over permanent color from scalp to ends on previously uncolored hair.</span>
          </td>
          <td class="price">$80</td>
        </tr>

        <tr><th class="section-header" colspan="2">SPECIALTY COLOR</th></tr>
        <tr><td>Ombré</td><td class="price">$125 &amp; up</td></tr>
        <tr><td>Balayage</td><td class="price">$125 &amp; up</td></tr>
        <tr><td>Every color blend</td><td class="price">$15 each color</td></tr>

        <tr><th class="section-header" colspan="2">SMOOTHING TREATMENTS</th></tr>
        <tr>
          <td>
            Keratin Smoothing Treatment
            <span class="note">Aldehyde-free &amp; formaldehyde-free. Adds volume, smooths, and restores youthful texture for a minimum of 4 months.</span>
          </td>
          <td class="price">$230 &amp; up</td>
        </tr>
        <tr>
          <td>
            Keratin Express Treatment
            <span class="note">100% formaldehyde-free amino acid express treatment. Up to 4 weeks of softer, frizz-free hair.</span>
          </td>
          <td class="price">$45 <span class="note">($35 with any cut or color service)</span></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;

      buttons.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('active'));

      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      document.getElementById(`tab-${target}`)?.classList.add('active');
    });
  });
</script>
